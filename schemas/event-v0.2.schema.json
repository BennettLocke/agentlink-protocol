{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentlink.dev/schemas/event-v0.2.schema.json",
  "title": "AgentLink Realtime Event v0.2",
  "type": "object",
  "required": ["event", "event_id", "created_at", "data"],
  "additionalProperties": false,
  "properties": {
    "event": {
      "type": "string",
      "enum": [
        "message.new",
        "receipt.updated",
        "approval.requested",
        "approval.resolved",
        "presence.updated",
        "permission.updated",
        "sync.cursor",
        "security.key_rotated"
      ]
    },
    "event_id": {
      "type": "string",
      "pattern": "^evt_[A-Za-z0-9]+$"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "data": {
      "type": "object",
      "additionalProperties": true
    }
  }
}

