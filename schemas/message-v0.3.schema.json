{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentlink.dev/schemas/message-v0.3.schema.json",
  "title": "AgentLink Message Envelope v0.3",
  "type": "object",
  "required": ["protocol", "conversation_id", "from", "to", "sender_mode", "content"],
  "additionalProperties": false,
  "properties": {
    "protocol": {
      "type": "string",
      "const": "agentlink.message.v0.3"
    },
    "message_id": {
      "type": "string",
      "pattern": "^msg_[A-Za-z0-9]+$"
    },
    "client_msg_id": {
      "type": "string",
      "minLength": 1
    },
    "conversation_id": {
      "type": "string",
      "pattern": "^conv_[A-Za-z0-9]+$"
    },
    "from": {
      "$ref": "actor.schema.json"
    },
    "on_behalf_of": {
      "$ref": "actor.schema.json"
    },
    "to": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "actor.schema.json"
      }
    },
    "sender_mode": {
      "type": "string",
      "enum": ["human_sent", "agent_drafted", "agent_sent", "app_sent", "system_sent"]
    },
    "content": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "text"],
          "additionalProperties": false,
          "properties": {
            "type": {
              "type": "string",
              "const": "text"
            },
            "text": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type",
            "suite",
            "alg",
            "key_id",
            "key_version",
            "nonce",
            "ciphertext",
            "tag"
          ],
          "additionalProperties": false,
          "properties": {
            "type": {
              "type": "string",
              "const": "ciphertext"
            },
            "suite": {
              "type": "string",
              "enum": ["agentlink.e2ee.v1", "agentlink.local-cache.v1"]
            },
            "alg": {
              "type": "string",
              "enum": ["aes-256-gcm", "chacha20-poly1305"]
            },
            "key_id": {
              "type": "string",
              "minLength": 1
            },
            "key_version": {
              "type": "integer",
              "minimum": 1
            },
            "nonce": {
              "type": "string",
              "minLength": 8
            },
            "ciphertext": {
              "type": "string",
              "minLength": 1
            },
            "tag": {
              "type": "string",
              "minLength": 1
            },
            "aad": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "security": {
      "type": "object",
      "required": ["transport", "content_protection"],
      "additionalProperties": false,
      "properties": {
        "transport": {
          "type": "string",
          "enum": ["tls"]
        },
        "content_protection": {
          "type": "string",
          "enum": ["plaintext", "server_protected", "e2ee"]
        },
        "suite": {
          "type": "string",
          "minLength": 1
        },
        "key_id": {
          "type": "string",
          "minLength": 1
        },
        "key_version": {
          "type": "integer",
          "minimum": 1
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "nonce": {
          "type": "string",
          "minLength": 8
        },
        "signer_device_key_id": {
          "type": "string",
          "pattern": "^devkey_[A-Za-z0-9]+$"
        },
        "signer_agent_crypto_key_id": {
          "type": "string",
          "pattern": "^agkey_[A-Za-z0-9]+$"
        },
        "signed": {
          "type": "boolean"
        },
        "signature_alg": {
          "type": "string",
          "enum": ["ed25519", "none"]
        },
        "signature": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "approval": {
          "type": "string",
          "enum": ["not_required", "required", "granted", "denied"]
        },
        "sensitive": {
          "type": "boolean"
        },
        "requires_human_reply": {
          "type": "boolean"
        },
        "visibility": {
          "type": "string",
          "enum": ["participants", "owner_only", "server_audit"]
        }
      }
    },
    "receipts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "actor", "created_at"],
        "additionalProperties": false,
        "properties": {
          "receipt_id": {
            "type": "string",
            "pattern": "^rcp_[A-Za-z0-9]+$"
          },
          "type": {
            "type": "string",
            "enum": ["sent", "delivered", "read", "failed", "revoked"]
          },
          "actor": {
            "$ref": "actor.schema.json"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "request_id": {
          "type": "string",
          "pattern": "^req_[A-Za-z0-9]+$"
        },
        "trace_id": {
          "type": "string",
          "pattern": "^trc_[A-Za-z0-9]+$"
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
