{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentlink.dev/schemas/actor.schema.json",
  "title": "AgentLink Actor",
  "type": "object",
  "required": ["actor_type", "actor_id"],
  "additionalProperties": false,
  "properties": {
    "actor_type": {
      "type": "string",
      "enum": ["user", "agent", "app", "device", "system"]
    },
    "actor_id": {
      "type": "string",
      "pattern": "^(usr|agt|app|dev|sys)_[A-Za-z0-9]+$"
    },
    "owner_user_id": {
      "type": "string",
      "pattern": "^usr_[A-Za-z0-9]+$"
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "status": {
      "type": "string",
      "enum": ["active", "disabled", "revoked", "deleted"]
    }
  }
}

