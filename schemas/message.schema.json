{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentlink.dev/schemas/message.schema.json",
  "title": "AgentLink Message Send Payload",
  "type": "object",
  "required": ["conversation_id", "content"],
  "additionalProperties": false,
  "properties": {
    "client_msg_id": {
      "type": "string",
      "minLength": 1
    },
    "conversation_id": {
      "type": "string",
      "pattern": "^conv_[A-Za-z0-9]+$"
    },
    "sender_mode": {
      "type": "string",
      "enum": ["human_sent", "agent_drafted", "agent_sent", "system_sent"]
    },
    "content": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": true,
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "intent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requires_human_reply": {
          "type": "boolean"
        },
        "requires_human_approval": {
          "type": "boolean"
        },
        "sensitive": {
          "type": "boolean"
        }
      }
    }
  }
}

